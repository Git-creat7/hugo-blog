 &lt;th&gt;备注 (Note)&lt;/th&gt;
 &lt;/tr&gt;
 &lt;/thead&gt;
 &lt;tbody&gt;
 &lt;tr&gt;
 &lt;td&gt;&lt;strong&gt;G&lt;/strong&gt;&lt;/td&gt;
